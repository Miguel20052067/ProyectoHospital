# CONFIGURACIÓN PARA PRODUCCIÓN EN SERVIDOR DEL INSTITUTO
# Copia este archivo a .env.prod y actualiza con valores reales

# Backend Spring Boot (conecta a BD existente del instituto)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/casosclinicos
SPRING_DATASOURCE_USERNAME=tu_usuario_bd
SPRING_DATASOURCE_PASSWORD=tu_contraseña_bd
SERVER_PORT=8080

# OAuth2 Google
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# Frontend
FRONTEND_API_URL=http://localhost:8080
